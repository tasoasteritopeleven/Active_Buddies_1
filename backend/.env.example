# =========================================================
# Active Buddies Backend - Environment Variables
# Copy this file to `.env` and fill in real values.
# =========================================================

# ---- App ----
NODE_ENV=development
PORT=4000
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
LOG_LEVEL=debug

# ---- Database (PostgreSQL) ----
# Local Docker Compose default:
DATABASE_URL=postgresql://activebuddies:activebuddies@localhost:5432/activebuddies?schema=public

# ---- Redis (Cache + Pub/Sub + BullMQ) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-me-too-different-from-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Rate limiting ----
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ---- Feature flags ----
ENABLE_SWAGGER=true
ENABLE_WEBSOCKETS=true
