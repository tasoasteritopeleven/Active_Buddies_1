// =========================================================
// Active Buddies — Prisma Schema
// PostgreSQL primary. Designed for horizontal scale.
// =========================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Enums -----------------------------------------------

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

enum ConversationType {
  DIRECT
  GROUP
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  MESSAGE
  CHALLENGE_JOIN
  CHALLENGE_COMPLETE
  COMMUNITY_INVITE
  MENTION
  SYSTEM
}

enum CommunityMemberRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum ChallengeType {
  STEPS
  DISTANCE
  DURATION
  STREAK
  CUSTOM
}

// ---- Models ----------------------------------------------

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  bio           String?
  avatarUrl     String?
  fitnessLevel  String?
  goals         String[] @default([])
  preferences   Json?
  role          UserRole @default(USER)

  // Location (lat/lng as separate columns for Prisma portability)
  locationLat   Float?
  locationLng   Float?
  locationCity  String?

  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  // Relations
  refreshTokens          RefreshToken[]
  sentConnections        Connection[]          @relation("ConnectionRequester")
  receivedConnections    Connection[]          @relation("ConnectionAddressee")
  sentMessages           Message[]             @relation("MessageSender")
  participants           ConversationParticipant[]
  notifications          Notification[]
  challengesCreated      Challenge[]           @relation("ChallengeCreator")
  challengeParticipants  ChallengeParticipant[]
  communitiesCreated     Community[]           @relation("CommunityCreator")
  communityMemberships   CommunityMember[]
  activityLogs           ActivityLog[]

  @@index([email])
  @@index([createdAt])
  @@index([isActive, deletedAt])
  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  userAgent  String?
  ipAddress  String?

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Connection {
  id              String           @id @default(uuid()) @db.Uuid
  requesterId     String           @db.Uuid
  addresseeId     String           @db.Uuid
  status          ConnectionStatus @default(PENDING)
  matchScore      Float?
  message         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  respondedAt     DateTime?

  requester       User             @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee       User             @relation("ConnectionAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@map("connections")
}

model Conversation {
  id          String            @id @default(uuid()) @db.Uuid
  type        ConversationType  @default(DIRECT)
  name        String?
  avatarUrl   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  lastMessageAt DateTime?

  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  userId         String   @db.Uuid
  joinedAt       DateTime @default(now())
  leftAt         DateTime?
  lastReadAt     DateTime?
  isAdmin        Boolean  @default(false)

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  senderId       String       @db.Uuid
  content        String
  type           MessageType  @default(TEXT)
  attachments    Json?
  isEdited       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model Challenge {
  id                 String        @id @default(uuid()) @db.Uuid
  title              String
  description        String?
  challengeType      ChallengeType @default(CUSTOM)
  startDate          DateTime
  endDate            DateTime
  createdById        String        @db.Uuid
  participantsCount  Int           @default(0)
  isActive           Boolean       @default(true)
  rules              Json?
  rewards            Json?
  targetValue        Float?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  createdBy          User          @relation("ChallengeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants       ChallengeParticipant[]

  @@index([createdById])
  @@index([startDate, endDate])
  @@index([isActive])
  @@map("challenges")
}

model ChallengeParticipant {
  id           String    @id @default(uuid()) @db.Uuid
  challengeId  String    @db.Uuid
  userId       String    @db.Uuid
  progress     Float     @default(0)
  rank         Int?
  joinedAt     DateTime  @default(now())
  completedAt  DateTime?

  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId, rank])
  @@index([userId])
  @@map("challenge_participants")
}

model Community {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  icon           String?
  color          String?
  bannerUrl      String?
  membersCount   Int       @default(0)
  createdById    String    @db.Uuid
  isPublic       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  createdBy      User              @relation("CommunityCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members        CommunityMember[]

  @@index([createdById])
  @@index([isPublic])
  @@index([name])
  @@map("communities")
}

model CommunityMember {
  id           String               @id @default(uuid()) @db.Uuid
  communityId  String               @db.Uuid
  userId       String               @db.Uuid
  role         CommunityMemberRole  @default(MEMBER)
  joinedAt     DateTime             @default(now())

  community    Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
  @@map("community_members")
}

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @db.Uuid
  type       NotificationType
  title      String
  message    String?
  data       Json?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model ActivityLog {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  activityType  String
  description   String?
  metadata      Json?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([activityType])
  @@map("activity_logs")
}
